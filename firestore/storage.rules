rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{uid}/{file=**} {
      allow read: if true;
      allow write: if request.auth.uid == uid && request.resource.size < 2 * 1024 * 1024;
    }
    match /receipts/{orderId}/{file=**} {
      allow read: if request.auth.token.role in ['OWNER','RECEPTIONIST'];
      allow write: if request.auth.token.role in ['OWNER','RECEPTIONIST'];
    }
  }
}
